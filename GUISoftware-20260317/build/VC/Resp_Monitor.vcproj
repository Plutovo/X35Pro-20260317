<?xml version="1.0" encoding="gb2312"?>
<VisualStudioProject
	ProjectType="Visual C++"
	Version="7.10"
	Name="Resp_Monitor"
	RootNamespace="Resp_Monitor"
	SccProjectName=""
	SccLocalPath="">
	<Platforms>
		<Platform
			Name="Win32"/>
	</Platforms>
	<Configurations>
		<Configuration
			Name="Release|Win32"
			OutputDirectory=".\Output\WIN32_MSVC60\Release"
			IntermediateDirectory=".\Output\WIN32_MSVC60\Release"
			ConfigurationType="1"
			UseOfMFC="0"
			ATLMinimizesCRunTimeLibraryUsage="FALSE"
			CharacterSet="2">
			<Tool
				Name="VCCLCompilerTool"
				Optimization="1"
				InlineFunctionExpansion="1"
				OptimizeForProcessor="1"
				AdditionalIncludeDirectories="Config,GUI\Core,GUI\Widget,GUI\WM,System\Simulation,System\Simulation\Res,GUI\LCDDriver"
				PreprocessorDefinitions="LCD_USE_WINSIM;NDEBUG;WIN32;_WINDOWS"
				StringPooling="TRUE"
				RuntimeLibrary="0"
				EnableFunctionLevelLinking="TRUE"
				PrecompiledHeaderFile=".\Output\WIN32_MSVC60\Release/Resp_Monitor.pch"
				AssemblerListingLocation=".\Output\WIN32_MSVC60\Release/"
				ObjectFile=".\Output\WIN32_MSVC60\Release/"
				ProgramDataBaseFileName=".\Output\WIN32_MSVC60\Release/"
				BrowseInformation="1"
				WarningLevel="3"
				SuppressStartupBanner="TRUE"
				CompileAs="0"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalDependencies="libcmt.lib libc.lib System\Simulation\GUISim.lib winmm.lib odbc32.lib odbccp32.lib"
				OutputFile=".\Output\WIN32_MSVC60\Release/Resp_Monitor.exe"
				LinkIncremental="1"
				SuppressStartupBanner="TRUE"
				GenerateMapFile="TRUE"
				MapFileName=".\Output\WIN32_MSVC60\Release/Resp_Monitor.map"
				SubSystem="2"
				TargetMachine="1"/>
			<Tool
				Name="VCMIDLTool"
				PreprocessorDefinitions="NDEBUG"
				MkTypLibCompatible="TRUE"
				SuppressStartupBanner="TRUE"
				TargetEnvironment="1"
				TypeLibraryName=".\Output\WIN32_MSVC60\Release/Resp_Monitor.tlb"
				HeaderFileName=""/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"
				PreprocessorDefinitions="NDEBUG"
				Culture="1031"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
		<Configuration
			Name="Debug|Win32"
			OutputDirectory="..\..\..\VS_Debug"
			IntermediateDirectory="..\..\..\VS_Debug"
			ConfigurationType="1"
			UseOfMFC="0"
			ATLMinimizesCRunTimeLibraryUsage="FALSE"
			CharacterSet="2"
			ReferencesPath="">
			<Tool
				Name="VCCLCompilerTool"
				Optimization="0"
				OptimizeForProcessor="1"
				AdditionalIncludeDirectories="..\..\GUI\AntiAlias;..\..\GUI\Font;..\..\Application\language;..\..\GUI\ConvertColor;..\..\GUIConfig;..\..\GUI\Core;..\..\GUI\Widget;..\..\GUI\MemDev;..\..\GUI\WM;System\Simulation;..\..\GUI\MultiLayer;..\..\GUI\ConvertMono;System\Simulation\Res;..\..\GUI\LCDDriver;..\..\GUI\JPEG;..\..\Application;..\..\Application\Check_include;..\..\Application\Debug_App;..\..\Application\os_Prio;..\..\Application\DispStrsLib"
				PreprocessorDefinitions="LCD_USE_WINSIM;_DEBUG;WIN32;_WINDOWS"
				BasicRuntimeChecks="3"
				RuntimeLibrary="4"
				UsePrecompiledHeader="0"
				PrecompiledHeaderFile="..\..\..\VS_Debug/Resp_Monitor.pch"
				AssemblerListingLocation="../../../VS_Debug/"
				ObjectFile="../../../VS_Debug/"
				ProgramDataBaseFileName="../../../VS_Debug/"
				BrowseInformation="1"
				WarningLevel="3"
				SuppressStartupBanner="TRUE"
				DebugInformationFormat="1"
				CompileAs="0"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalDependencies="System\Simulation\GUISim.lib winmm.lib odbc32.lib odbccp32.lib"
				OutputFile="..\..\..\VS_Debug/X45Demo.exe"
				LinkIncremental="1"
				SuppressStartupBanner="TRUE"
				IgnoreDefaultLibraryNames="libcmt.lib"
				GenerateDebugInformation="TRUE"
				ProgramDatabaseFile="..\..\..\VS_Debug/Resp_Monitor.pdb"
				SubSystem="2"
				StackReserveSize="10000000"
				StackCommitSize="10000000"
				TargetMachine="1"/>
			<Tool
				Name="VCMIDLTool"
				PreprocessorDefinitions="_DEBUG"
				MkTypLibCompatible="TRUE"
				SuppressStartupBanner="TRUE"
				TargetEnvironment="1"
				TypeLibraryName=".\Output\WIN32_MSVC60\Debug/Resp_Monitor.tlb"
				HeaderFileName=""/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"
				CommandLine="..\..\build\VC\vs_prebuild.bat"
				ExcludedFromBuild="FALSE"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"
				PreprocessorDefinitions="_DEBUG"
				Culture="1031"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
	</Configurations>
